# Copy to .env and fill in your values:
#   cp .env.example .env

# Kalshi API credentials (both required for authenticated endpoints)
KALSHI_API_KEY_ID=your-api-key-id-here
KALSHI_PRIVATE_KEY_PATH=/path/to/your/kalshi-key.key

# API base URL
KALSHI_BASE_URL=https://external-api.kalshi.com/trade-api/v2
# KALSHI_BASE_URL=https://external-api.demo.kalshi.co/trade-api/v2

# ETL pipeline settings
MIN_SERIES_VOLUME=1000
MAX_SERIES_TO_SCORE=200
TOP_VOLATILE_SERIES=10
SCORE_CONCURRENCY=3
LOOKBACK_DAYS=30
PERIOD_INTERVAL=60
MAX_MARKETS_PER_SERIES=50
CANDLESTICK_CONCURRENCY=2
DATA_DIR=data

# Supabase / Postgres connection string for Alembic + backend loaders
# Use the Supabase database password, not the anon key.
# Example:
# DATABASE_URL=postgresql+psycopg://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=
